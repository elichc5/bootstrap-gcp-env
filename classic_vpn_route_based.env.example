# Example configuration for provision_classic_vpn_route_based.sh
# This file complements bootstrap_gcp_env.sh or any equivalent script that
# already created the base VPCs and subnets.

GCP_ACCOUNT="jfchanac@trustedcloudsolutions.lat"

CONNECTION_NAME="hybrid-lab"
IKE_VERSION="2"
ROUTE_PRIORITY="1000"
VPN_FW_RULES="all"
VPN_SHARED_SECRET="replace-with-a-strong-pre-shared-key"
RUN_POST_VALIDATION="false"

LEFT_SITE_NAME="onprem-01"
LEFT_PROJECT_ID="project-onprem-01"
LEFT_NETWORK="vpc-onprem-01-core"
LEFT_REGION="us-central1"
LEFT_LOCAL_CIDRS="10.10.10.0/24,10.10.20.0/24"
LEFT_TEST_VM_NAME="vm-onprem-01-bastion"
LEFT_TEST_VM_ZONE="us-central1-a"
LEFT_PING_TARGETS="10.20.10.2,10.20.10.3"

RIGHT_SITE_NAME="cloud-01"
RIGHT_PROJECT_ID="project-cloud-01-498217"
RIGHT_NETWORK="vpc-cloud-01-core"
RIGHT_REGION="us-central1"
RIGHT_LOCAL_CIDRS="10.20.10.0/24,10.20.20.0/24"
RIGHT_TEST_VM_NAME="vm-cloud-01-bastion"
RIGHT_TEST_VM_ZONE="us-central1-a"
RIGHT_PING_TARGETS="10.10.10.2,10.10.20.2"
